    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Stargate (Simulation Mode)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/bin/python",
            "env": {
                "PYTHONPATH": "${workspaceFolder}:${workspaceFolder}/classes:${workspaceFolder}/classes/StargateMilkyWay:${workspaceFolder}/config"
            },
            "justMyCode": false,
            "stopOnEntry": false,
            "args": []
        }
    ]
}

